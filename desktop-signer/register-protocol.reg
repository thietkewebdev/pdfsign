Windows Registry Editor Version 5.00

[HKEY_CURRENT_USER\Software\Classes\pdfsignpro]
@="URL:PDFSignPro Protocol"
"URL Protocol"=""

[HKEY_CURRENT_USER\Software\Classes\pdfsignpro\DefaultIcon]
@="C:\\Path\\To\\PDFSignProSigner.exe,1"

[HKEY_CURRENT_USER\Software\Classes\pdfsignpro\shell\open\command]
@="\"C:\\Path\\To\\PDFSignProSigner.exe\" \"%1\""
