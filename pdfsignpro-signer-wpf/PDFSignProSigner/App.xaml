<Application x:Class="PDFSignProSigner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="App_OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <!-- zinc-950, zinc-900 - Linear-like dark theme -->
            <SolidColorBrush x:Key="BgPrimaryBrush" Color="#FF09090B"/>
            <SolidColorBrush x:Key="BgSecondaryBrush" Color="#FF18181B"/>
            <SolidColorBrush x:Key="BgTertiaryBrush" Color="#FF27272A"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFAFAFA"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFA1A1AA"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#FF3F3F46"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6"/>

            <!-- Form controls dark theme - ComboBoxItem must be defined before ComboBox references it -->
            <Style x:Key="ComboBoxItemDarkStyle" TargetType="ComboBoxItem">
                <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Padding" Value="8,6"/>
                <Style.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter Property="Background" Value="#FF3F3F46"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemDarkStyle}"/>
            </Style>
            <Style TargetType="PasswordBox">
                <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
