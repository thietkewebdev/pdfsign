<Window x:Class="PDFSignProSigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDFSignPro Signer"
        Height="620" Width="480"
        MinHeight="420" MinWidth="320"
        Background="{StaticResource BgPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel x:Name="HeaderPanel" Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="MainTitleText" Text="PDFSignPro Signer"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock x:Name="SubtitleText" Text="Mở qua liên kết pdfsignpro:// để ký tài liệu"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content area - screens -->
        <Border x:Name="MainContentBorder" Grid.Row="1"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <Grid>
                <!-- Idle -->
                <StackPanel x:Name="IdlePanel" Visibility="Visible">
                    <TextBlock Text="Chưa có tài liệu cần ký"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14" TextWrapping="Wrap"/>
                    <TextBlock Text="Mở liên kết pdfsignpro:// từ trình duyệt hoặc email để bắt đầu."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    <Border Margin="0,20,0,0" Padding="12" CornerRadius="6"
                            Background="{StaticResource BgTertiaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Tuỳ chọn Signer" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="IdleCheckUpdates" Content="Kiểm tra bản mới khi mở ứng dụng"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      Margin="0,0,0,8" Checked="IdleSettings_Changed" Unchecked="IdleSettings_Changed"/>
                            <CheckBox x:Name="IdleRemindUsb" Content="Nhắc rút USB token sau khi ký (balloon khay hệ thống)"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      Margin="0,0,0,12" Checked="IdleSettings_Changed" Unchecked="IdleSettings_Changed"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Kiểm tra cập nhật ngay" Click="CheckUpdatesNow_Click"
                                        Padding="12,6" Margin="0,0,8,0"
                                        Background="{StaticResource BgSecondaryBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                <Button Content="Mở thư mục nhật ký" Click="OpenLogFolder_Click"
                                        Padding="12,6"
                                        Background="{StaticResource BgSecondaryBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                            </StackPanel>
                            <Button Content="Xóa chứng chỉ ưu tiên (nhiều cert trên token)" Click="ClearPreferredCert_Click"
                                    HorizontalAlignment="Left" Padding="12,6"
                                    Background="{StaticResource BgSecondaryBrush}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                            <TextBlock Text="Nhật ký: %LocalAppData%\PDFSignProSigner\logs\app.log (xoay khi đầy)."
                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Loading -->
                <StackPanel x:Name="LoadingPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="4" Width="200" Margin="0,0,0,16"/>
                    <TextBlock x:Name="LoadingText" Text="Đang tải..."
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                </StackPanel>

                <!-- Sign -->
                <ScrollViewer x:Name="SignPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="DocTitleText" Text="Tài liệu"
                                   FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <!-- PIN: ẩn khi dùng PIN đã lưu; Enter = Ký số (kiểm tra PIN + ký nếu 1 chứng chỉ) -->
                        <StackPanel x:Name="PinInputPanel">
                            <TextBlock Text="Mã PIN" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="PinBox" Height="36" Margin="0,0,0,8"
                                         FontSize="14"
                                         PasswordChanged="PinBox_PasswordChanged"
                                         KeyDown="PinBox_KeyDown"/>
                        </StackPanel>
                        <TextBlock x:Name="VerifyPinResultText" Text=""
                                  Foreground="#22C55E" FontSize="12" Margin="0,0,0,4"
                                  Visibility="Collapsed"/>
                        <TextBlock x:Name="LockoutWarningText"
                                  Text="⚠ Sai PIN nhiều lần có thể khóa token."
                                  Foreground="#F59E0B" FontSize="11"
                                  TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <!-- Cert loading state -->
                        <StackPanel x:Name="CertLoadingPanel" Visibility="Collapsed" Orientation="Horizontal" Margin="0,0,0,12">
                            <ProgressBar IsIndeterminate="True" Height="3" Width="120" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Đang đọc chứng thư…" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Signature templates - ẩn khi ký từ web, mẫu cố định từ deep link -->
                        <StackPanel x:Name="TemplateSelectorPanel" Visibility="Collapsed">
                            <TextBlock Text="Mẫu chữ ký" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                            <ListBox x:Name="TemplateList" MinHeight="120" MaxHeight="160" Margin="0,0,0,12"
                                 Background="{StaticResource BgTertiaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Padding="8"
                                 SelectionChanged="TemplateList_SelectionChanged">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="100" Height="52" Padding="6" CornerRadius="4"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            Background="{StaticResource BgSecondaryBrush}"
                                            ClipToBounds="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding PreviewText}" FontSize="9" Margin="0,2,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </StackPanel>
                        <!-- Cert dropdown (chỉ khi có từ 2 chứng chỉ) -->
                        <TextBlock x:Name="CertLabel" Text="Chứng chỉ" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" Visibility="Collapsed"/>
                        <ComboBox x:Name="CertCombo" MinHeight="44" Margin="0,0,0,8"
                                  Visibility="Collapsed"
                                  IsEnabled="False"
                                  SelectionChanged="CertCombo_SelectionChanged"
                                  Background="{StaticResource BgTertiaryBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  Padding="8,6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding CompanyName}" FontWeight="SemiBold" FontSize="13"
                                                   TextWrapping="Wrap" MaxWidth="380"
                                                   Foreground="{StaticResource ComboBoxFgBrush}"/>
                                        <TextBlock Text="{Binding ExpiryDisplay}" FontSize="11" Margin="0,2,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <CheckBox x:Name="PreferThisCertCheckBox" Visibility="Collapsed"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="11" Margin="0,0,0,16"
                                  Checked="PreferThisCertCheckBox_Changed" Unchecked="PreferThisCertCheckBox_Changed">
                            <TextBlock Text="Luôn chọn chứng chỉ này khi có nhiều chứng chỉ (ghi nhớ theo serial)"
                                       TextWrapping="Wrap"/>
                        </CheckBox>
                        <Button x:Name="SignBtn" Content="Ký số"
                                Click="Sign_Click"
                                ToolTip="Nhập PIN rồi bấm: kiểm tra PIN và ký (một bước nếu chỉ có một chứng chỉ)."
                                IsEnabled="False"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White" FontWeight="SemiBold"
                                Padding="24,12" HorizontalAlignment="Stretch"/>
                        <TextBlock x:Name="SignErrorText" Foreground="#F87171" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,12,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Signing (progress) -->
                <StackPanel x:Name="SigningPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="4" Width="200" Margin="0,0,0,16"/>
                    <TextBlock x:Name="SigningText" Text="Đang ký PDF..."
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <TextBlock x:Name="SigningLog" Text="" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"
                               Margin="0,12,0,0" MaxWidth="360"/>
                </StackPanel>

                <!-- Success -->
                <StackPanel x:Name="SuccessPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="✓ Đã ký thành công"
                               FontSize="18" FontWeight="SemiBold" Foreground="#22C55E"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <Button x:Name="DownloadPdfBtn" Content="Tải PDF đã ký"
                            Click="DownloadPdf_Click"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White" FontWeight="SemiBold"
                            Padding="24,12" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SuccessErrorText" Text="Không nhận được liên kết từ server."
                               Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Margin="0,12,0,0" MaxWidth="320"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
