# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/pdfsignpro?schema=public"

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_BUCKET="pdfsign"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Alternative: use R2_ACCOUNT_ID instead of R2_ENDPOINT
# R2_ACCOUNT_ID=""
# R2_BUCKET_NAME="pdfsignpro"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_GA4_ID="G-XXXXXXXXXX"

# Storage: "r2" | "s3" (R2/S3) | "local" (files in .storage/uploads).
# If unset in development and R2_* are missing, the app uses local automatically.
STORAGE_DRIVER="r2"

# PDF viewer: default = same-origin /api/documents/.../file + pdf.js Range requests (fast preview).
# Set to "1" to use presigned R2 URL in the browser (needs R2 CORS). When unset, metadata API skips
# presigning to save latency.
# NEXT_PUBLIC_PDF_DIRECT_R2="1"

# Signer download (R2 key for Windows exe, used by /api/signer/download)
SIGNER_R2_KEY="signer/PDFSignProSigner.exe"

# Offline app download (R2 key for setup exe, used by /api/download/offline)
OFFLINE_R2_KEY="SignOffline/PDFSignPro_Setup.exe"

# Offline app download URL (shown in homepage; if unset, offline card is hidden)
NEXT_PUBLIC_OFFLINE_APP_URL="https://pdfsign.vn/api/download/offline"

# SHA-256 checksum of PDFSignPro_Setup.exe (displayed on /offline page)
OFFLINE_SHA256=""

# Auth (NextAuth.js v5) — set at least one secret in production
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Comma-separated admin emails allowed to access /admin and /api/admin/*
ADMIN_EMAIL_WHITELIST="admin@pdfsign.vn"

# Email (Resend - dùng cho hợp đồng điện tử)
RESEND_API_KEY=""
EMAIL_FROM="PDFSignPro <noreply@pdfsign.vn>"
# App URL phải là domain thực để email verify tạo link đúng
# NEXTAUTH_URL="https://pdfsign.vn"

# Telegram (gửi thông báo khi có liên hệ mới)
# Tạo bot qua @BotFather, lấy token. Chat ID: dùng @userinfobot hoặc tạo group thêm bot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
