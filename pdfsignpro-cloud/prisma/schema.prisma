generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(cuid())
  publicId  String   @unique
  title     String?
  status    String   @default("ACTIVE") // ACTIVE, ARCHIVED
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  versions  DocumentVersion[]
  jobs      SigningJob[]

  @@index([userId])
}

model DocumentVersion {
  id             String   @id @default(cuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version        Int      // 1, 2, 3...
  storageKey     String
  storageDriver String   @default("r2")
  sizeBytes      Int
  createdAt      DateTime @default(now())
  jobsAsInput    SigningJob[] @relation("InputVersion")
  jobsAsOutput   SigningJob[] @relation("OutputVersion")

  @@unique([documentId, version])
  @@index([documentId])
}

model SigningJob {
  id                  String    @id @default(cuid())
  documentVersionId   String    // input version being signed
  documentVersion     DocumentVersion @relation("InputVersion", fields: [documentVersionId], references: [id], onDelete: Cascade)
  documentId          String
  document            Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  jobTokenHash        String    // sha256 of jobToken
  jobToken            String?   // raw token for claim exchange (new jobs only)
  claimCodeHash       String?   // sha256 of short claim code (new jobs only)
  status              String    @default("CREATED") // CREATED, COMPLETED, EXPIRED, CANCELED
  placementJson       String    // JSON: { page, rectPct: { x, y, w, h } }
  sealImageKey        String?   // storage key for seal image (template=seal)
  certMetaJson        String?   // JSON: subject O/CN, serial, signingTime...
  outputVersionId     String?   // new DocumentVersion when completed
  outputVersion       DocumentVersion? @relation("OutputVersion", fields: [outputVersionId], references: [id])
  createdAt           DateTime  @default(now())
  completedAt         DateTime?
  claimedAt           DateTime? // when claim code was exchanged for token
  expiresAt           DateTime  // job expires after 30m

  @@index([documentVersionId])
  @@index([documentId])
  @@index([jobTokenHash])
  @@index([claimCodeHash])
}
