generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  contracts     Contract[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(cuid())
  publicId  String   @unique
  title     String?
  status    String   @default("ACTIVE") // ACTIVE, ARCHIVED
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  versions  DocumentVersion[]
  jobs      SigningJob[]
  contracts Contract[]

  @@index([userId])
}

model DocumentVersion {
  id             String   @id @default(cuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version        Int      // 1, 2, 3...
  storageKey     String
  storageDriver String   @default("r2")
  sizeBytes      Int
  createdAt      DateTime @default(now())
  jobsAsInput    SigningJob[] @relation("InputVersion")
  jobsAsOutput   SigningJob[] @relation("OutputVersion")

  @@unique([documentId, version])
  @@index([documentId])
}

model SigningJob {
  id                  String    @id @default(cuid())
  documentVersionId   String    // input version being signed
  documentVersion     DocumentVersion @relation("InputVersion", fields: [documentVersionId], references: [id], onDelete: Cascade)
  documentId          String
  document            Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  jobTokenHash        String    // sha256 of jobToken
  jobToken            String?   // raw token for claim exchange (new jobs only)
  claimCodeHash       String?   // sha256 of short claim code (new jobs only)
  status              String    @default("CREATED") // CREATED, COMPLETED, EXPIRED, CANCELED
  placementJson       String    // JSON: { page, rectPct: { x, y, w, h } }
  sealImageKey        String?   // storage key for seal image (template=seal)
  certMetaJson        String?   // JSON: subject O/CN, serial, signingTime...
  outputVersionId     String?   // new DocumentVersion when completed
  outputVersion       DocumentVersion? @relation("OutputVersion", fields: [outputVersionId], references: [id])
  createdAt           DateTime  @default(now())
  completedAt         DateTime?
  claimedAt           DateTime? // when claim code was exchanged for token
  expiresAt           DateTime  // job expires after 30m

  contractSigner  ContractSigner?

  @@index([documentVersionId])
  @@index([documentId])
  @@index([jobTokenHash])
  @@index([claimCodeHash])
}

model Contract {
  id          String    @id @default(cuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  message     String?
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, EXPIRED
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  completedAt DateTime?
  signers     ContractSigner[]
  events      ContractEvent[]

  @@index([userId])
  @@index([documentId])
}

model ContractSigner {
  id            String     @id @default(cuid())
  contractId    String
  contract      Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  email         String
  name          String
  order         Int
  status        String     @default("PENDING") // PENDING, INVITED, COMPLETED
  token         String     @unique
  placementJson String
  templateId    String     @default("classic")
  signingJobId  String?    @unique
  signingJob    SigningJob? @relation(fields: [signingJobId], references: [id])
  invitedAt     DateTime?
  completedAt   DateTime?

  @@unique([contractId, order])
  @@index([token])
}

model ContractEvent {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type        String   // CREATED, INVITED, VIEWED, SIGNED, COMPLETED, CANCELLED, REMINDED
  actor       String?  // email or name of who triggered this event
  detail      String?  // extra info (e.g. signer name, order)
  createdAt   DateTime @default(now())

  @@index([contractId])
}
